# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).

# --- API-Football ---
# Usada para fixtures (jogos), busca de times, detalhes e elenco.
# Cadastre-se em https://www.api-football.com/ e gere sua chave.
API_FOOTBALL_KEY=sua_chave_aqui
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- football-data.org ---
# Usada para CLASSIFICAÇÕES da temporada atual (o free da API-Football
# só libera até 2024). Cadastre-se em https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=seu_token_aqui
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# --- CORS ---
# URL onde o frontend vai rodar (Vite usa 5173 por padrão)
FRONTEND_ORIGIN=http://localhost:5173
